{
  "name": "nexphy",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "nexphy": "./dist/node/cli.js"
  },
  "files": [
    "dist/node/**"
  ],
  "exports": {
    ".": "./dist/node/cli.js"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build --compile src/cli.ts --outfile dist/tsgraph",
    "build:node": "bun scripts/build-node.ts",
    "build:bins": "bun scripts/build-bins.ts",
    "build:all": "bun run build:node && bun run build:bins",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:node": "node --experimental-strip-types --test tests/storage/node-sqlite.test.ts",
    "lint": "bunx @biomejs/biome check .",
    "proto:infomap": "bun run prototypes/infomap-bun.ts",
    "proto:tree-sitter": "bun run prototypes/tree-sitter-bun.ts",
    "proto:all": "bun run scripts/validate-prototypes.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "smol-toml": "^1.6.1",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  }
}
